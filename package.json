{
  "name": "armorybot",
  "version": "0.10.0",
  "type": "module",
  "description": "Discord Bot for AnneMunition's Armory",
  "private": true,
  "author": "DBKynd <db@dbkynd.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0"
  },
  "engineStrict": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch -r dotenv/config ./src/index.ts",
    "build": "rimraf ./dist && tsc -p ./tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node -r dotenv/config ./dist",
    "prettier": "prettier --write \"**/*.{js,ts,md,*rc,json}\" --ignore-path .gitignore",
    "lint": "eslint --ext .js,.ts --ignore-pattern .gitignore .",
    "test": "jest",
    "docker:build": "docker build -t dbkynd/armory-bot:latest ."
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs-node": "^4.22.0",
    "axios": "^1.18.0",
    "bufferutil": "^4.1.0",
    "cheerio": "^1.2.0",
    "cron": "^4.4.0",
    "discord.js": "^14.26.4",
    "emoji-regex": "^10.6.0",
    "erlpack": "^0.1.4",
    "getos": "^3.2.1",
    "html-entities": "^2.6.0",
    "humanize-duration": "^3.33.2",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "mathjs": "^15.2.0",
    "mongoose": "^9.7.1",
    "node-vibrant": "4.0.4",
    "os": "^0.1.2",
    "pidusage": "^4.0.1",
    "rgb2hex": "^0.2.5",
    "sharp": "^0.35.2",
    "temp-units-conv": "^1.0.2",
    "utf-8-validate": "^6.0.6",
    "winston": "^3.19.0",
    "zlib-sync": "^0.1.10"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@types/getos": "^3.0.4",
    "@types/humanize-duration": "^3.27.4",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.0",
    "@types/pidusage": "^2.0.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "mockdate": "^3.0.5",
    "nock": "^14.0.15",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
